# ============================================================
# FinDocRAG Environment Variables
# Copy this file to .env and fill in the values.
# See: docs/technical-design-document.md Sections 5, 8, 9
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=findocrag
POSTGRES_USER=findocrag
POSTGRES_PASSWORD=changeme

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- LLM Backend (ollama | openai | claude) ---
LLM_BACKEND=ollama

# --- Ollama (if LLM_BACKEND=ollama) ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b

# --- OpenAI (if LLM_BACKEND=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Anthropic / Claude (if LLM_BACKEND=claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Query API ---
API_KEYS=dev-key-1,dev-key-2
QUERY_API_PORT=8000
RATE_LIMIT=30/minute
# Comma-separated allowed CORS origins; use * to allow all (default)
CORS_ORIGINS=*

# --- SEC EDGAR ---
# SEC requires a User-Agent with your name and email
EDGAR_USER_AGENT=FinDocRAG changeme@gmail.com
EDGAR_RATE_LIMIT_RPS=10

# --- Embedding Drift Detection (CronJob) ---
# URL of the Prometheus Pushgateway to push drift metrics to
# PUSHGATEWAY_URL=http://pushgateway:9091
# Cosine distance threshold above which a drift alert is emitted (default: 0.15)
# DRIFT_THRESHOLD=0.15
# Number of days of recent embeddings to compare against the corpus mean (default: 7)
# DRIFT_LOOKBACK_DAYS=7

# --- Evaluation Harness (services/eval/run_eval.py) ---
# Base URL of the Query API to evaluate against (default: http://localhost:8000)
# EVAL_API_URL=http://localhost:8000
# API key for the Query API (default: dev-key-1)
# EVAL_API_KEY=dev-key-1
# Claude model to use as the ragas judge (default: claude-haiku-4-5)
# CLAUDE_JUDGE_MODEL=claude-haiku-4-5
# Ollama URL and model for the ragas judge fallback (used when no API key is set)
# EVAL_OLLAMA_URL=http://localhost:11434
# EVAL_OLLAMA_MODEL=mistral:7b

# --- Logging ---
LOG_LEVEL=INFO