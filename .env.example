# ============================================================
# FinDocRAG Environment Variables
# Copy this file to .env and fill in the values.
# See: docs/technical-design-document.md Sections 5, 8, 9
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=findocrag
POSTGRES_USER=findocrag
POSTGRES_PASSWORD=changeme

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- LLM Backend (ollama | openai) ---
LLM_BACKEND=ollama

# --- Ollama (if LLM_BACKEND=ollama) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral:7b

# --- OpenAI (if LLM_BACKEND=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embedding Model ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Query API ---
API_KEYS=dev-key-1,dev-key-2
QUERY_API_PORT=8000
RATE_LIMIT=30/minute

# --- SEC EDGAR ---
# SEC requires a User-Agent with your name and email
EDGAR_USER_AGENT=FinDocRAG changeme@gmail.com
EDGAR_RATE_LIMIT_RPS=10

# --- Logging ---
LOG_LEVEL=INFO