{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Query Request Rate & Error Rate",
      "description": "Rate of incoming queries and errors per second.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors/sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(findoc_query_requests_total[5m]))",
          "legendFormat": "requests/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(findoc_query_errors_total[5m]))",
          "legendFormat": "errors/sec",
          "refId": "B"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Query Latency — Total (p50 / p95 / p99)",
      "description": "End-to-end query latency percentiles.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(findoc_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(findoc_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(findoc_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Latency Breakdown (stacked)",
      "description": "Average latency breakdown: embedding, retrieval, LLM generation.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "stacking": { "mode": "normal" }, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "avg(findoc_query_embedding_duration_ms)",
          "legendFormat": "embedding",
          "refId": "A"
        },
        {
          "expr": "avg(findoc_query_retrieval_duration_ms)",
          "legendFormat": "retrieval",
          "refId": "B"
        },
        {
          "expr": "avg(findoc_query_generation_duration_ms)",
          "legendFormat": "LLM generation",
          "refId": "C"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Top-1 Retrieval Relevance Score",
      "description": "Distribution of the cosine similarity score for the top-ranked chunk.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(findoc_query_top1_relevance_bucket[5m])) by (le))",
          "legendFormat": "p50 relevance",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(findoc_query_top1_relevance_bucket[5m])) by (le))",
          "legendFormat": "p95 relevance",
          "refId": "B"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "LLM Token Consumption Rate",
      "description": "Rate of tokens consumed by the LLM backend (prompt vs completion).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(findoc_query_llm_tokens_used[5m])) by (backend, type)",
          "legendFormat": "{{backend}} — {{type}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Degraded Response Rate",
      "description": "Rate of responses returned in degraded mode (e.g., retrieval-only, no LLM).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "spanNulls": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "degraded/sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(findoc_query_degraded_responses_total[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "title": "Embedding Drift Score",
      "description": "Cosine distance between recent and corpus mean embeddings (from weekly CronJob).",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.15 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "findoc_embedding_drift_score",
          "legendFormat": "drift score",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Drift Alert Status",
      "description": "1 = drift exceeds threshold (0.15), 0 = normal.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            { "options": { "0": { "text": "OK", "color": "green" }, "1": { "text": "DRIFT ALERT", "color": "red" } }, "type": "value" }
          ],
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "findoc_embedding_drift_alert",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" }
    }
  ],
  "schemaVersion": 39,
  "tags": ["findoc-rag", "query", "llm", "performance"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "FinDocDRAG — Query Performance",
  "uid": "findoc-query",
  "version": 1
}